{
  "name": "hakoniwa-chart-catalog",
  "private": true,
  "version": "0.1.0-alpha.1",
  "description": "LLM でチャート投稿 JSON を生成し、React + sandbox iframe で描画するプロジェクトです。",
  "author": "Taniory",
  "license": "MIT",
  "homepage": "https://Taniory.github.io/HakoniwaChartCatalog/",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host",
    "embed:dompurify": "node scripts/run_python.mjs -m scripts.embed_dompurify",
    "embed:sandbox-runtime": "node scripts/embed_sandbox_runtime.mjs",
    "test:sandbox-sanitizer": "node --test tests/sandbox_sanitizer.test.mjs",
    "generate:index": "node scripts/run_python.mjs scripts/build_index.py",
    "generate:thumbnails": "node scripts/generate-thumbnails.js",
    "venv:setup": "python -m venv .venv && node scripts/run_python.mjs -m pip install -r requirements.txt"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "dompurify": "^3.3.1",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-json-view-lite": "^2.5.0",
    "react-syntax-highlighter": "^16.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.2",
    "puppeteer": "^24.39.1",
    "vite": "^5.4.10"
  }
}
