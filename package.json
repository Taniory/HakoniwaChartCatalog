{
  "name": "daily-uncommon-charts",
  "private": true,
  "version": "0.1.0-alpha.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host",
    "embed:dompurify": "python -m scripts.embed_dompurify",
    "embed:sandbox-runtime": "node scripts/embed_sandbox_runtime.mjs",
    "test:sandbox-sanitizer": "node --test tests/sandbox_sanitizer.test.mjs",
    "generate": "python scripts/generate_daily_post.py && npm run generate:index",
    "generate:index": "python scripts/build_index.py"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "dompurify": "^3.3.1",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-json-view-lite": "^2.5.0",
    "react-syntax-highlighter": "^16.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.2",
    "vite": "^5.4.10"
  }
}
