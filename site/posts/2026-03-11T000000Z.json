  "transform_js": "const dataMap = {};\nlet root = {};\n// 階層データ（再帰ツリー）を構築\nrawData.rows.forEach(r => {\n  dataMap[r.id] = { name: r.id, value: r.value, children: [] };\n});\nrawData.rows.forEach(r => {\n  if (r.parent && dataMap[r.parent]) {\n    dataMap[r.parent].children.push(dataMap[r.id]);\n  } else {\n    root = dataMap[r.id];\n  }\n});\n// echarts の data はルート配列を要求する\ntransformedData = [root];",
