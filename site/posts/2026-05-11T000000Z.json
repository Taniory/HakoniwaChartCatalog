  "transform_js": "var groups={},all=[];rawData.rows.forEach(function(r){var g=r.g!=null?r.g:r.group;var v=Number(r.v!=null?r.v:r.value);if(g==null||!isFinite(v))return;if(!groups[g])groups[g]=[];groups[g].push(v);all.push(v);});var cats=Object.keys(groups);var min=Math.min.apply(null,all),max=Math.max.apply(null,all);if(!isFinite(min)||!isFinite(max)){min=0;max=1;}if(min===max){min-=1;max+=1;}var pad=(max-min)*0.08;min-=pad;max+=pad;var span=max-min;var ry=0.025,rx=0.075,step=0.03,maxLayer=80;var seriesMap={};cats.forEach(function(g){seriesMap[g]=[];});cats.forEach(function(g,gi){var arr=groups[g].slice().sort(function(a,b){return a-b;});var placed=[];arr.forEach(function(v){var yn=(v-min)/span;var chosen=0;var found=false;for(var layer=0;layer<=maxLayer&&!found;layer++){var cands=layer===0?[0]:[layer*step,-layer*step];for(var ci=0;ci<cands.length&&!found;ci++){var xoff=cands[ci],ok=true;for(var j=0;j<placed.length;j++){var p=placed[j],dx=(xoff-p.x)/rx,dy=(yn-p.y)/ry;if(dx*dx+dy*dy<1){ok=false;break;}}if(ok){chosen=xoff;found=true;}}}placed.push({x:chosen,y:yn,v:v});seriesMap[g].push([gi+1+chosen,v]);});});transformedData={cats:cats,min:min,max:max,series:cats.map(function(g){return{name:g,data:seriesMap[g]};})};",
  "echarts_js": "option={title:{text:'Distribution (Beeswarm)',left:'center',top:8,textStyle:{fontSize:16,fontWeight:'bold'}},grid:{left:54,right:24,top:56,bottom:56},tooltip:{trigger:'item',formatter:function(p){return p.seriesName+'<br/>Value: '+p.value[1];}},xAxis:{type:'value',min:0.5,max:transformedData.cats.length+0.5,interval:1,axisTick:{show:false},axisLine:{show:false},splitLine:{show:false},axisLabel:{formatter:function(v){var i=Math.round(v)-1;return i>=0&&i<transformedData.cats.length?transformedData.cats[i]:'';}}},yAxis:{type:'value',name:'Value',nameLocation:'middle',nameGap:40,min:transformedData.min,max:transformedData.max,splitLine:{show:true,lineStyle:{color:'rgba(0,0,0,0.08)'}}},legend:{top:30,data:transformedData.cats,itemWidth:10,itemHeight:10,textStyle:{fontSize:11}},series:transformedData.series.map(function(s){return{type:'scatter',name:s.name,data:s.data,symbolSize:9,itemStyle:{opacity:0.78},emphasis:{scale:1.18}};})};",
